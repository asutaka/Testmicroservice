{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Yarp": "Warning"
        }
    },
    "Auth": {
        "Authority": "http://localhost:5000",
        "Audience": "MicroservicesApp"
    },
    "ReverseProxy": {
        "Routes": {
            "user-service-route": {
                "ClusterId": "user-service-cluster",
                "RateLimiterPolicy": "global",
                "Match": {
                    "Path": "/api/users/{**catch-all}"
                },
                "Transforms": [
                    {
                        "PathPattern": "/api/v1/users/{**catch-all}"
                    }
                ]
            },
            "order-service-route": {
                "ClusterId": "order-service-cluster",
                "RateLimiterPolicy": "global",
                "Match": {
                    "Path": "/api/orders/{**catch-all}"
                },
                "Transforms": [
                    {
                        "PathPattern": "/api/v1/orders/{**catch-all}"
                    }
                ]
            },
            "payment-service-route": {
                "ClusterId": "payment-service-cluster",
                "RateLimiterPolicy": "global",
                "Match": {
                    "Path": "/api/payments/{**catch-all}"
                },
                "Transforms": [
                    {
                        "PathPattern": "/api/v1/payments/{**catch-all}"
                    }
                ]
            },
            "web-bff-route": {
                "ClusterId": "web-bff-cluster",
                "Match": {
                    "Path": "/bff/web/{**catch-all}"
                }
            }
        },
        "Clusters": {
            "user-service-cluster": {
                "Destinations": {
                    "user-service": {
                        "Address": "http://localhost:5001"
                    }
                },
                "HealthCheck": {
                    "Active": {
                        "Enabled": true,
                        "Interval": "00:00:10",
                        "Path": "/health"
                    }
                }
            },
            "order-service-cluster": {
                "Destinations": {
                    "order-service": {
                        "Address": "http://localhost:5002"
                    }
                },
                "HealthCheck": {
                    "Active": {
                        "Enabled": true,
                        "Interval": "00:00:10",
                        "Path": "/health"
                    }
                }
            },
            "payment-service-cluster": {
                "Destinations": {
                    "payment-service": {
                        "Address": "http://localhost:5003"
                    }
                }
            },
            "web-bff-cluster": {
                "Destinations": {
                    "web-bff": {
                        "Address": "http://localhost:5010"
                    }
                }
            }
        }
    },
    "Kestrel": {
        "Endpoints": {
            "Http": {
                "Url": "http://localhost:5000"
            }
        }
    },
    "AllowedHosts": "*"
}